Package: SpaTopic
Type: Package
Title: Topic Inference to Identify Tissue Architecture in Multiplexed
        Images
Version: 1.2.0.9000
Date: 2025-02-27
Authors@R: c(
  person("Xiyu", "Peng", email = "pansypeng124@gmail.com",
